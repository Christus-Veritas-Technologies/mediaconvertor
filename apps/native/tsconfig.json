{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "paths": {
      "@/*": ["./*"],
      "@MediaConvertor/conversion": ["../../packages/conversion/src/index.ts"],
      "@MediaConvertor/conversion/*": ["../../packages/conversion/src/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "**/*.d.ts", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
